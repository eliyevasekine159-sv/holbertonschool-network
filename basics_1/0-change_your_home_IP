#!/usr/bin/env bash
# Configures local IP resolution safely and passes shellcheck
# Useless cat xətasından qaçmaq üçün faylı birbaşa sed ilə oxuyub yönləndiririk
sed 's/\b127\.0\.0\.1\b/127.0.0.2/g' /etc/hosts > /etc/hosts.tmp
mv -f /etc/hosts.tmp /etc/hosts

# facebook.com yönləndirməsini əlavə edirik (əgər yoxdursa)
if ! grep -q "facebook.com" /etc/hosts; then
    echo "8.8.8.8 facebook.com" >> /etc/hosts
fi
