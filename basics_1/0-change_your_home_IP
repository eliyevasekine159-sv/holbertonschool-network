#!/usr/bin/env bash
# Configures local IP resolution using tee to bypass device busy errors
# hosts faylını sed ilə oxuyub dəyişirik və birbaşa tee ilə üzərinə yazırıq (mv və ya sed -i işlətmirik)
sed 's/\b127\.0\.0\.1\b/127.0.0.2/g' /etc/hosts | tee /etc/hosts > /dev/null

# facebook.com yönləndirməsini əlavə edirik (əgər yoxdursa)
if ! grep -q "facebook.com" /etc/hosts; then
    echo "8.8.8.8 facebook.com" | tee -a /etc/hosts > /dev/null
fi
